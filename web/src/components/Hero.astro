---
---

<section class="hero" id="inicio">
  <div class="container hero__inner">

    <div class="hero__content">

      <span class="section-label">Consultoría Tecnológica · Lima, Perú</span>

      <h1 class="hero__title">
        Automatización <span class="accent">IA</span> y Energía en un solo lugar
      </h1>

      <p class="hero__subtitle">
        Desarrollamos soluciones reales en IA aplicada, sistemas fotovoltaicos
        e ingeniería de software — con experiencia comprobada en infraestructura
        energética del Perú.
      </p>

      <div class="hero__actions">
        <a href="#contacto" class="btn-primary">Cuéntanos tu proyecto</a>
        <a href="#servicios" class="btn-secondary">Ver servicios</a>
      </div>

    </div>

    <div class="hero__visual">
      <div class="hero__graphic">

        <!-- Tarjeta 1 — CAMBIO 2 -->
        <div class="hero__card hero__card--1">
          <span class="hero__card-icon">⚡</span>
          <div>
            <p class="hero__card-label">Energía Inteligente</p>
            <p class="hero__card-value">Solar · BESS · Híbrido</p>
          </div>
        </div>

        <!-- Centro animado -->
        <div class="hero__center">
          <div class="hero__ring hero__ring--outer"></div>
          <div class="hero__ring hero__ring--inner"></div>
          <div class="hero__core"><span>AI</span></div>
        </div>

        <!-- Tarjeta 2 — CAMBIO 2 -->
        <div class="hero__card hero__card--2">
          <span class="hero__card-icon">🤖</span>
          <div>
            <p class="hero__card-label">IA Aplicada</p>
            <p class="hero__card-value">ML · LLMs · Datos</p>
          </div>
        </div>

        <!-- Tarjeta 3 — CAMBIO 2 -->
        <div class="hero__card hero__card--3">
          <span class="hero__card-icon">💻</span>
          <div>
            <p class="hero__card-label">Ingeniería de Software</p>
            <p class="hero__card-value">APIs · Automatización · IoT</p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Banda inferior — CAMBIO 3: sin título, 4 métricas concretas -->
  <div class="hero__credentials">
    <div class="container hero__credentials-inner">
      <div class="hero__cred-items">

        <div class="hero__cred-item">
          <span class="hero__cred-icon">⚡</span>
          <span>3+ años en proyectos de transmisión eléctrica</span>
        </div>
        <div class="hero__cred-divider"></div>
        <div class="hero__cred-item">
          <span class="hero__cred-icon">☀️</span>
          <span>Hasta 30 KW instalados en zonas remotas y alta montaña</span>
        </div>
        <div class="hero__cred-divider"></div>
        <div class="hero__cred-item">
          <span class="hero__cred-icon">🤖</span>
          <span>Modelos de IA desplegados en producción real en Azure</span>
        </div>
        <div class="hero__cred-divider"></div>
        <div class="hero__cred-item">
          <span class="hero__cred-icon">🏔️</span>
          <span>+4,000 msnm — operaciones en condiciones extremas</span>
        </div>

      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 70px;
    background-color: var(--color-bg);
    position: relative;
    overflow: hidden;        /* ← evita que las tarjetas absolutas generen scroll */
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(27, 73, 101, 0.25) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-8);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  /* ── Contenido ── */
  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;        /* ← permite que el grid comprima esta columna */
    width: 100%;
  }

  .hero__title {
    font-size: clamp(1.1rem, 4.5vw, var(--text-5xl));
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-offwhite);
    text-wrap: balance;
    max-width: 100%;     /* ← sin restricción de caracteres */
    width: 100%;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  /* ── Visual ── */
  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__graphic {
    position: relative;
    width: 380px;
    height: 380px;
    flex-shrink: 0;
  }

  /* Anillos animados */
  .hero__center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
  }

  .hero__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--color-cyan);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.4;
    animation: pulse-ring 3s ease-in-out infinite;
  }

  .hero__ring--outer {
    width: 180px;
    height: 180px;
    animation-delay: 0s;
  }

  .hero__ring--inner {
    width: 140px;
    height: 140px;
    animation-delay: 0.5s;
    opacity: 0.6;
  }

  @keyframes pulse-ring {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.3; }
    50%       { transform: translate(-50%, -50%) scale(1.06); opacity: 0.6; }
  }

  .hero__core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, var(--color-petrol), var(--color-cyan));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-2xl);
    color: white;
    box-shadow: var(--shadow-cyan);
  }

  /* Tarjetas flotantes */
  .hero__card {
    position: absolute;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    box-shadow: var(--shadow-md);
    min-width: 190px;
    transition: transform 0.3s ease;
  }

  .hero__card:hover {
    transform: translateY(-4px) !important;
    border-color: var(--color-cyan);
  }

  .hero__card-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .hero__card-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-offwhite);
    margin: 0;
    line-height: 1.3;
  }

  .hero__card-value {
    font-size: var(--text-xs);
    color: var(--color-cyan);
    font-family: var(--font-mono);
    margin: 0;
    line-height: 1.3;
  }

  .hero__card--1 {
    top: 8%;
    left: 0%;           /* ← antes -5%, causaba overflow */
    animation: float 4s ease-in-out infinite;
  }

  .hero__card--2 {
    bottom: 12%;
    left: 0%;
    animation: float 4s ease-in-out infinite;
    animation-delay: 1s;
  }

  .hero__card--3 {
    top: 35%;
    right: 0%;          /* ← antes -8%, causaba overflow */
    animation: float 4s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px);  }
    50%       { transform: translateY(-8px); }
  }

  /* ── Credenciales ── */
  .hero__credentials {
    border-top: 1px solid var(--color-border);
    padding: var(--space-3) 0;
    background-color: var(--color-surface);
  }

  .hero__credentials-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__cred-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .hero__cred-items {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__cred-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-pearl);
  }

  .hero__cred-icon {
    font-size: 1rem;
  }

  .hero__cred-divider {
    width: 1px;
    height: 20px;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  /* ── Responsivo ── */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .hero__content {
      align-items: center;   /* ← centra todo el contenido en móvil */
    }

    .hero__title {
      font-size: clamp(1.1rem, 6.5vw, 2.2rem);  /* ← escala más agresivo en móvil */
      text-align: center;
    }

    .hero__subtitle {
      max-width: 100%;
      margin: 0 auto;
    }

    .hero__actions {
      justify-content: center;
    }

    /* Ocultamos el gráfico completamente — el overflow:hidden del padre lo contiene */
    .hero__visual {
      display: none;
    }

    .hero__credentials-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .hero__cred-divider {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero__title {
      font-size: clamp(1rem, 6vw, 1.6rem);
    }

    .container {
      padding: 0 var(--space-2);   /* Reduce padding lateral de 1.5rem a 1rem */
    }

    .hero__subtitle {
      font-size: var(--text-base);
    }
  }
</style>