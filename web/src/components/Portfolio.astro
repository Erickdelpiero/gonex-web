---
const proyectos = [
  {
    categoria: "Inteligencia Artificial · Energía",
    titulo: "⚡ Sistema de Optimización de Demanda en Transmisión Eléctrica",
    descripcion: "Modelo predictivo de series temporales para optimización de demanda energética en sistemas de transmisión eléctrica. Implementación de estrategias de Peak Shaving y Load Shifting sobre datos reales, con pipeline completo de ingesta, feature engineering, entrenamiento, validación y exposición vía API. Desplegado en Azure con cliente en operación real.",
    resultado: "Modelo en producción real con cliente activo — optimización de carga eléctrica en infraestructura de transmisión.",
    tags: ["Python", "Machine Learning", "Series Temporales", "Azure", "Peak Shaving"],
    sector: "Transmisión eléctrica · Sector energético peruano",
    icono: "⚡",
    destacado: true
  },
  {
    categoria: "Desarrollo de Software · Web",
    titulo: "Plataforma Web Institucional con Automatización de Procesos",
    descripcion: "Diseño y desarrollo completo de plataforma web institucional integrada con automatización de comunicaciones vía WhatsApp Business y flujos de trabajo digitales para una organización peruana.",
    resultado: "Digitalización completa de procesos de atención y comunicación con socios.",
    tags: ["Python", "Flask", "WhatsApp API", "N8N", "Evolution API"],
    sector: "Sector cooperativo · Servicios financieros",
    icono: "💻",
    destacado: false
  },
  {
    categoria: "Ingeniería · Energía Renovable",
    titulo: "Sistemas Fotovoltaicos Off-Grid e Híbridos en Alta Montaña",
    descripcion: "Diseño e instalación de sistemas fotovoltaicos Off-Grid e híbridos con capacidades de 1 KW a 30 KW para zonas rurales, minería y comunidades en alta montaña. Operaciones a más de 4,000 msnm en condiciones extremas, incluyendo conectividad Starlink, gestión de red LAN robusta y supervisión en tiempo real mediante soluciones cloud.",
    resultado: "Electrificación sostenible en zonas remotas y alta montaña con sistemas operativos en condiciones extremas.",
    tags: ["Solar FV", "Híbrido", "BESS", "Off-Grid", "Alta montaña", "+4,000 msnm"],
    sector: "Energía renovable · Comunidades rurales · Perú",
    icono: "☀️",
    destacado: false
  }
];
---

<section class="portfolio section" id="proyectos">
  <div class="container">

    <div class="portfolio__header">
      <span class="section-label">Proyectos ejecutados</span>
      <h2 class="section-title">
        Resultados <span class="accent">reales</span>
      </h2>
      <p class="section-subtitle">
        Trabajamos con empresas e instituciones que necesitan soluciones
        que funcionen en campo, no solo en papel.
      </p>
    </div>

    <div class="portfolio__list">
      {proyectos.map((proyecto, index) => (
        <div class={`portfolio-card ${proyecto.destacado ? 'portfolio-card--featured' : ''}`}>

          <!-- Número de proyecto -->
          <div class="portfolio-card__number">
            {String(index + 1).padStart(2, '0')}
          </div>

          <!-- Contenido principal -->
          <div class="portfolio-card__content">

            <div class="portfolio-card__top">
              <span class="portfolio-card__categoria">{proyecto.categoria}</span>
              {proyecto.destacado && (
                <span class="portfolio-card__badge">Proyecto destacado</span>
              )}
            </div>

            <div class="portfolio-card__main">
              <div class="portfolio-card__text">
                <h3 class="portfolio-card__titulo">
                  <span class="portfolio-card__icono">{proyecto.icono}</span>
                  {proyecto.titulo}
                </h3>
                <p class="portfolio-card__descripcion">{proyecto.descripcion}</p>

                <!-- Resultado clave -->
                <div class="portfolio-card__resultado">
                  <span class="portfolio-card__resultado-label">→ Resultado</span>
                  <span class="portfolio-card__resultado-text">{proyecto.resultado}</span>
                </div>
              </div>

              <!-- Metadatos -->
              <div class="portfolio-card__meta">
                <div class="portfolio-card__sector">
                  <span class="portfolio-card__meta-label">Sector</span>
                  <span class="portfolio-card__meta-value">{proyecto.sector}</span>
                </div>

                <div class="portfolio-card__tags">
                  {proyecto.tags.map(tag => (
                    <span class="service-card__tag">{tag}</span>
                  ))}
                </div>

                <a href="#contacto" class="btn-secondary portfolio-card__cta">
                  Proyecto similar →
                </a>
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

    <!-- CTA de cierre -->
    <div class="portfolio__footer">
      <p>¿Tienes un proyecto en mente? Conversemos.</p>
      <a href="#contacto" class="btn-primary">Agendar una llamada</a>
    </div>

  </div>
</section>

<style>
  .portfolio__header {
    max-width: 600px;
    margin-bottom: var(--space-8);
  }

  .portfolio__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ── Tarjeta ── */
  .portfolio-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: grid;
    grid-template-columns: 80px 1fr;
    overflow: hidden;
    transition: all 0.25s ease;
  }

  .portfolio-card:hover {
    border-color: var(--color-cyan);
    box-shadow: var(--shadow-md);
  }

  /* Tarjeta destacada — borde cyan desde el inicio */
  .portfolio-card--featured {
    border-color: var(--color-cyan);
    box-shadow: var(--shadow-cyan);
  }

  /* Columna izquierda — número */
  .portfolio-card__number {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-4xl);
    color: var(--color-border);
    background-color: var(--color-surface-2);
    border-right: 1px solid var(--color-border);
    padding: var(--space-4);
    transition: color 0.25s ease;
  }

  .portfolio-card:hover .portfolio-card__number,
  .portfolio-card--featured .portfolio-card__number {
    color: var(--color-cyan);
  }

  /* Columna derecha — contenido */
  .portfolio-card__content {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .portfolio-card__top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .portfolio-card__categoria {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-cyan);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .portfolio-card__badge {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-petrol);
    background-color: var(--color-cyan);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  /* Fila principal — texto + meta */
  .portfolio-card__main {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-6);
    align-items: start;
  }

  .portfolio-card__icono {
    margin-right: 0.5rem;
  }

  .portfolio-card__titulo {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-offwhite);
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .portfolio-card__descripcion {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  /* Resultado clave */
  .portfolio-card__resultado {
    display: flex;
    gap: 0.5rem;
    margin-top: var(--space-2);
    padding: var(--space-2);
    background-color: rgba(0, 180, 216, 0.06);
    border-left: 3px solid var(--color-cyan);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .portfolio-card__resultado-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-cyan);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .portfolio-card__resultado-text {
    font-size: var(--text-sm);
    color: var(--color-pearl);
    font-weight: 500;
  }

  /* Columna de metadatos */
  .portfolio-card__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-3);
  }

  .portfolio-card__meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .portfolio-card__meta-value {
    font-size: var(--text-sm);
    color: var(--color-pearl);
    font-weight: 500;
    line-height: 1.4;
  }

  .portfolio-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .portfolio-card__cta {
    font-size: var(--text-sm) !important;
    padding: 0.5rem 1rem !important;
    text-align: center;
    margin-top: auto;
  }

  /* ── Footer CTA ── */
  .portfolio__footer {
    margin-top: var(--space-8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .portfolio__footer p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* ── Responsivo ── */
  @media (max-width: 900px) {
    .portfolio-card {
      grid-template-columns: 1fr;
    }

    .portfolio-card__number {
      display: none;
    }

    .portfolio-card__main {
      grid-template-columns: 1fr;
    }

    .portfolio-card__meta {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: var(--space-2);
    }
  }
</style>