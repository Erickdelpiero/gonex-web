---
const servicios = [
  {
    icono: "⚙️",
    titulo: "Automatización Industrial",
    descripcion: "Diseño e implementación de sistemas de control para procesos industriales. Programación de PLCs, SCADA, HMI e integración con sistemas existentes.",
    tags: ["PLC", "SCADA", "HMI", "IoT"],
    color: "#00B4D8"
  },
  {
    icono: "🧠",
    titulo: "Inteligencia Artificial Aplicada",
    descripcion: "Modelos de machine learning y series temporales para predecir, clasificar y optimizar procesos reales. IA que resuelve problemas concretos de tu operación.",
    tags: ["Machine Learning", "Series temporales", "Python", "Azure"],
    color: "#1B4965"
  },
  {
    icono: "☀️",
    titulo: "Sistemas Fotovoltaicos y BESS",
    descripcion: "Dimensionamiento, diseño e ingeniería de sistemas de energía solar para industria, minería y zonas rurales. Incluye sistemas de almacenamiento de energía.",
    tags: ["Solar FV", "BESS", "Off-grid", "Expedientes técnicos"],
    color: "#F59E0B"
  },
  {
    icono: "💻",
    titulo: "Desarrollo de Software",
    descripcion: "Aplicaciones web, APIs, dashboards y herramientas a medida para empresas. Desde el prototipo hasta el deployment en producción.",
    tags: ["Flask", "Python", "APIs REST", "Docker"],
    color: "#10B981"
  },
  {
    icono: "📊",
    titulo: "Consultoría Tecnológica",
    descripcion: "Análisis, diagnóstico y planificación tecnológica para empresas que quieren modernizar sus operaciones sin desperdiciar inversión en soluciones incorrectas.",
    tags: ["Diagnóstico", "Arquitectura", "Estrategia TI"],
    color: "#8B5CF6"
  },
  {
    icono: "🎓",
    titulo: "Capacitación Empresarial",
    descripcion: "Formación técnica en inteligencia artificial, automatización y herramientas digitales para equipos de ingeniería y operaciones.",
    tags: ["Python", "IA", "Automatización", "In-company"],
    color: "#EF4444"
  }
];
---

<section class="services section" id="servicios">
  <div class="container">

    <!-- Encabezado de sección -->
    <div class="services__header">
      <span class="section-label">Lo que hacemos</span>
      <h2 class="section-title">
        Servicios <span class="accent">especializados</span>
      </h2>
      <p class="section-subtitle">
        Soluciones tecnológicas de ingeniería integradas. No vendemos herramientas
        aisladas — construimos sistemas que funcionan juntos.
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="services__grid">
      {servicios.map((servicio) => (
        <div class="service-card">

          <!-- Línea de acento izquierda — cambia de color por servicio -->
          <div
            class="service-card__accent"
            style={`background-color: ${servicio.color}`}
          ></div>

          <div class="service-card__body">

            <!-- Ícono y título -->
            <div class="service-card__header">
              <span class="service-card__icon">{servicio.icono}</span>
              <h3 class="service-card__title">{servicio.titulo}</h3>
            </div>

            <!-- Descripción -->
            <p class="service-card__desc">{servicio.descripcion}</p>

            <!-- Tags tecnológicos -->
            <div class="service-card__tags">
              {servicio.tags.map((tag) => (
                <span class="service-card__tag">{tag}</span>
              ))}
            </div>

            <!-- Link de acción -->
            <a href="#contacto" class="service-card__link">
              Consultar sobre este servicio →
            </a>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Encabezado ── */
  .services__header {
    max-width: 600px;
    margin-bottom: var(--space-8);
  }

  /* ── Grid ── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  /* ── Tarjeta ── */
  .service-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    overflow: hidden;           /* Para que la línea izquierda no se salga */
    transition: all 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-cyan);
  }

  /* Línea de color izquierda — identifica cada servicio visualmente */
  .service-card__accent {
    width: 4px;
    flex-shrink: 0;
  }

  .service-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  /* ── Header de la tarjeta ── */
  .service-card__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .service-card__icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .service-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-offwhite);
    line-height: 1.3;
  }

  /* ── Descripción ── */
  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.75;
    flex: 1;                    /* Empuja los tags y el link hacia abajo */
  }

  /* ── Tags ── */
  .service-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .service-card__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-cyan);
    background-color: rgba(0, 180, 216, 0.08);
    border: 1px solid rgba(0, 180, 216, 0.2);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
  }

  /* ── Link de acción ── */
  .service-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-cyan);
    text-decoration: none;
    margin-top: var(--space-1);
    transition: gap 0.2s ease;
    display: inline-block;
  }

  .service-card__link:hover {
    color: var(--color-cyan-dark);
    letter-spacing: 0.02em;
  }

  /* ── Responsivo ── */
  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>