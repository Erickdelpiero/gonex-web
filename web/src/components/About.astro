---
const valores = [
  {
    icono: "🎯",
    titulo: "Soluciones que funcionan en campo",
    descripcion: "No diseñamos en teoría. Cada solución la validamos contra la realidad operativa del cliente — desde plantas industriales hasta instalaciones a 4,000 msnm."
  },
  {
    icono: "🔗",
    titulo: "Integración real entre disciplinas",
    descripcion: "Combinamos IA, automatización y energía en un solo equipo. Sin intermediarios, sin traducción entre especialistas — todo bajo una misma visión de ingeniería."
  },
  {
    icono: "📐",
    titulo: "Rigor técnico con claridad ejecutiva",
    descripcion: "Hablamos el idioma del ingeniero de campo y del gerente que aprueba el presupuesto. La tecnología compleja explicada en términos de resultados y retorno."
  },
  {
    icono: "🌱",
    titulo: "Tecnología con impacto sostenible",
    descripcion: "Priorizamos soluciones que generan valor a largo plazo — energías renovables, sistemas eficientes y automatización que reduce desperdicios operativos."
  }
];

const credenciales = [
  { valor: "3+", etiqueta: "años en proyectos de infraestructura crítica" },
  { valor: "MSc", etiqueta: "Maestría en Inteligencia Artificial" },
  { valor: "CIP", etiqueta: "Colegio de Ingenieros del Perú" },
  { valor: "4,000", etiqueta: "msnm — proyectos en condiciones extremas" },
];
---

<section class="about section" id="nosotros">
  <div class="container">

    <!-- Encabezado -->
    <div class="about__header">
      <span class="section-label">Quiénes somos</span>
      <h2 class="section-title">
        Ingeniería peruana con <span class="accent">visión global</span>
      </h2>
    </div>

    <!-- Layout principal: texto + credenciales -->
    <div class="about__main">

      <!-- Columna izquierda — narrative -->
      <div class="about__story">
        <p class="about__lead">
          GONEX nace de la convicción de que la industria peruana merece
          soluciones tecnológicas de primer nivel — no adaptaciones de segundo
          orden de tecnologías diseñadas para otros mercados.
        </p>
        <p>
          Somos una consultora tecnológica especializada en la intersección
          de tres áreas que normalmente operan en silos: inteligencia artificial,
          automatización industrial y energía renovable. Esa integración es
          nuestra ventaja real.
        </p>
        <p>
          Hemos trabajado en proyectos de infraestructura crítica nacional,
          electrificado comunidades rurales en zonas de alta montaña y desarrollado
          modelos de IA que hoy optimizan operaciones del sistema eléctrico peruano.
        </p>
        <p>
          Fundada en Lima, operamos en todo el Perú con proyección
          hacia el mercado latinoamericano.
        </p>

        <!-- Métricas -->
        <div class="about__metrics">
          {credenciales.map(c => (
            <div class="about__metric">
              <span class="about__metric-valor">{c.valor}</span>
              <span class="about__metric-etiqueta">{c.etiqueta}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Columna derecha — visual con misión/visión -->
      <div class="about__mision-box">

        <div class="about__mv-item">
          <div class="about__mv-header">
            <span class="about__mv-icon">🧭</span>
            <h4 class="about__mv-title">Misión</h4>
          </div>
          <p class="about__mv-text">
            Acelerar la transformación tecnológica de la industria peruana
            mediante soluciones de ingeniería integradas — donde la inteligencia
            artificial, la automatización y la energía limpia trabajan juntas
            para crear operaciones más eficientes y sostenibles.
          </p>
        </div>

        <div class="about__mv-divider"></div>

        <div class="about__mv-item">
          <div class="about__mv-header">
            <span class="about__mv-icon">🔭</span>
            <h4 class="about__mv-title">Visión</h4>
          </div>
          <p class="about__mv-text">
            Ser la consultora tecnológica de referencia en Latinoamérica
            para empresas industriales que buscan integrar IA y energías
            renovables en sus operaciones, con la profundidad técnica
            y el criterio de ingeniería que el sector exige.
          </p>
        </div>

        <!-- Badge de ubicación -->
        <div class="about__location">
          <span>📍</span>
          <span>Lima, Perú — con proyección LATAM</span>
        </div>

      </div>
    </div>

    <!-- Valores -->
    <div class="about__valores">
      <h3 class="about__valores-title">
        Cómo trabajamos
      </h3>
      <div class="about__valores-grid">
        {valores.map(v => (
          <div class="about__valor-card">
            <span class="about__valor-icon">{v.icono}</span>
            <h4 class="about__valor-titulo">{v.titulo}</h4>
            <p class="about__valor-desc">{v.descripcion}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Header ── */
  .about__header {
    max-width: 600px;
    margin-bottom: var(--space-8);
  }

  /* ── Layout principal ── */
  .about__main {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-8);
    align-items: start;
    margin-bottom: var(--space-12);
  }

  /* ── Historia / narrative ── */
  .about__story {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .about__lead {
    font-size: var(--text-lg);
    color: var(--color-pearl);
    font-weight: 500;
    line-height: 1.75;
    border-left: 3px solid var(--color-cyan);
    padding-left: var(--space-3);
  }

  .about__story p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  /* ── Métricas ── */
  .about__metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .about__metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .about__metric-valor {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-3xl);
    color: var(--color-cyan);
    line-height: 1;
  }

  .about__metric-etiqueta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Caja misión/visión ── */
  .about__mision-box {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: sticky;
    top: 90px;              /* Se queda visible al hacer scroll, bajo el navbar */
  }

  .about__mv-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about__mv-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .about__mv-icon {
    font-size: 1.25rem;
  }

  .about__mv-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-offwhite);
  }

  .about__mv-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .about__mv-divider {
    height: 1px;
    background-color: var(--color-border);
  }

  .about__location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  /* ── Valores ── */
  .about__valores-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-offwhite);
    margin-bottom: var(--space-4);
  }

  .about__valores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  .about__valor-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: all 0.25s ease;
  }

  .about__valor-card:hover {
    border-color: var(--color-cyan);
    transform: translateY(-3px);
  }

  .about__valor-icon {
    font-size: 1.75rem;
  }

  .about__valor-titulo {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-offwhite);
    line-height: 1.3;
  }

  .about__valor-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ── Responsivo ── */
  @media (max-width: 1024px) {
    .about__valores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .about__main {
      grid-template-columns: 1fr;
    }

    .about__mision-box {
      position: static;
    }

    .about__metrics {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .about__valores-grid {
      grid-template-columns: 1fr;
    }

    .about__metrics {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>